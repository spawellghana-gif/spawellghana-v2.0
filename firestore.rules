rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if a user is authenticated and not anonymous
    function isAuthenticatedUser() {
      return request.auth != null && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Leads Collection Rules
    match /leads/{leadId} {
      allow read, write: if isAuthenticatedUser();
    }

    // Customers Collection Rules
    match /customers/{customerId} {
      allow read, write: if isAuthenticatedUser();
    }

    // Services Collection Rules
    match /services/{serviceId} {
      allow read, write: if isAuthenticatedUser();
    }

    // Bookings Collection Rules
    match /bookings/{bookingId} {
      allow read, write: if isAuthenticatedUser();
    }

    // Employees Collection Rules
    match /employees/{employeeId} {
      allow read, write: if isAuthenticatedUser();
    }

    // Partners Collection Rules
    match /partners/{partnerId} {
      allow read, write: if isAuthenticatedUser();
    }
  }
}
